# Transmission RPC connection
TR_HOST=localhost
TR_PORT=9091
TR_USER=transmission
TR_PASSWORD=changeme

# Matrix notifications (optional).
# If any of these are unset, notify() no-ops silently — the watcher still
# works without them.
MATRIX_HOMESERVER=http://localhost:8008
MATRIX_USER=bot
MATRIX_PASSWORD=changeme
MATRIX_ROOM_ID=!yourRoomId:your.matrix.server
